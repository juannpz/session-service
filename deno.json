{
    "tasks": {
        "dev": "deno run --allow-all --watch index.ts",
        "start": "deno run --allow-all index.ts"
    },
    "imports": {
        "@felix/bcrypt": "jsr:@felix/bcrypt@^1.0.8",
        "@juannpz/deno-service-tools": "jsr:@juannpz/deno-service-tools@0.5.7-4",
        "@juannpz/extra-sql": "jsr:@juannpz/extra-sql@0.0.8",
        "@std/dotenv": "jsr:@std/dotenv@^0.225.5"
    },
    "lint": {
        "rules": {
            "tags": ["recommended"]
        }
    },
    "fmt": {
        "options": {
            "useTabs": false,
            "indentWidth": 4,
            "lineWidth": 100
        }
    }
}
